{
  "id": "openclaw-webchat-plugin",
  "kind": "channel",
  "channels": ["openclaw-webchat"],
  "name": "WebChat",
  "description": "Browser-based WebChat channel for OpenClaw",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "channelConfigs": {
    "openclaw-webchat": {
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "serverUrl": { "type": "string", "description": "Chat Server WebSocket URL" },
          "accounts": {
            "type": "object",
            "description": "Map of accountId -> {appId, secret, serverUrl}",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "appId": { "type": "string" },
                "secret": { "type": "string" },
                "serverUrl": { "type": "string" }
              },
              "required": ["appId", "secret"]
            }
          }
        }
      }
    }
  }
}
